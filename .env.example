PORT=5000
MONGO_URI=mongodb://localhost:27017/api-etokisana?replicaSet=rs0
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# SMTP Configuration
SMTP_HOST=your_smtp_host
SMTP_PORT=your_smtp_port
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=your_smtp_from
SMTP_SECURE=true
SMTP_FROM_NAME=your_smtp_from_name
# Délai entre chaque envoi d'email (ms) — adapter selon votre prestataire SMTP
MAIL_SEND_DELAY_MS=300
# Nombre de tentatives max avant abandon d'un email
MAIL_MAX_RETRIES=3

# Application Configuration
APP_NAME=CommerceGestion
APP_URL=http://localhost:5000
# Admin Email
ADMIN_EMAIL=admin@example.com

# CORS Configuration
CORS_ALLOWLIST=http://localhost:3000,http://localhost:4200
FRONTEND_URL=http://localhost:3000


# Seeder Configuration
SUPERADMIN_EMAIL=superadmin@commercegestion.com
SUPERADMIN_PASSWORD=SuperSecurePassword2026!
